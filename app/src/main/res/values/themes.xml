<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SmartPetrolCalculator" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/malaysia_red</item>
        <item name="colorPrimaryVariant">@color/malaysia_red_dark</item>
        <item name="colorOnPrimary">@color/malaysia_white</item>
        <item name="colorSecondary">@color/malaysia_yellow</item>
        <item name="colorOnSecondary">@color/malaysia_blue</item>
        <item name="android:statusBarColor">@color/malaysia_red_dark</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/malaysia_red</item>
        <item name="android:textColor">@color/malaysia_white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.App.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/malaysia_red</item>
        <item name="android:textColor">@color/malaysia_red</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="TextAppearance.App.ResultLabel" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.App.ResultValue" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/malaysia_blue</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>